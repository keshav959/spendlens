{
  "info": {
    "name": "SpendLens - Expense Tracker API",
    "description": "Complete REST API collection for the Personal Expense Tracker",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["if (pm.response.json().data) { pm.collectionVariables.set('token', pm.response.json().data.token); }"] }
          }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["if (pm.response.json().data) { pm.collectionVariables.set('token', pm.response.json().data.token); }"] }
          }]
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "Create Expense",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/expenses",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Grocery Shopping\",\n  \"description\": \"Weekly groceries at D-Mart\",\n  \"amount\": 1250.50,\n  \"category\": \"FOOD\",\n  \"expenseDate\": \"2025-01-15\"\n}"
            }
          }
        },
        {
          "name": "Get All Expenses",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/expenses",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Paginated Expenses",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/expenses/paginated?page=0&size=10&sortBy=expenseDate&direction=desc",
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sortBy", "value": "expenseDate" },
                { "key": "direction", "value": "desc" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Expense by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/expenses/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Expense",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/expenses/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Grocery\",\n  \"amount\": 1500.00,\n  \"category\": \"FOOD\",\n  \"expenseDate\": \"2025-01-15\"\n}"
            }
          }
        },
        {
          "name": "Delete Expense",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/expenses/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get by Category",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/expenses/category/FOOD",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get by Date Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/expenses/date-range?start=2025-01-01&end=2025-01-31",
              "query": [
                { "key": "start", "value": "2025-01-01" },
                { "key": "end", "value": "2025-01-31" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/expenses/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
